{
  "manifest_version": 3,
  "name": "Recruitment Automation - RESDEX Screener",
  "version": "0.2.0",
  "description": "AI-powered candidate screening for Naukri RESDEX",
  "permissions": ["storage", "activeTab", "tabs", "downloads"],
  "host_permissions": [
    "https://resdex.naukri.com/*",
    "http://localhost:3002/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://resdex.naukri.com/*"],
      "js": ["dist/content-script.js"],
      "css": ["dist/content-script.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RecruitAI Screener"
  },
  "icons": {}
}
